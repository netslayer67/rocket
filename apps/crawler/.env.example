# The existing Nest API that owns pattern extraction and persistence.
CRAWLER_API_URL=http://localhost:4000
CRAWLER_USER_AGENT=RocketProjectCrawler/0.1
# One page is safest. Raising it follows only the exact same domain.
CRAWLER_MAX_PAGES=1
CRAWLER_DOWNLOAD_DELAY=2
CRAWLER_MAX_DELAY_SECONDS=12
CRAWLER_TIMEOUT_SECONDS=15
CRAWLER_MAX_RESPONSE_BYTES=1000000
